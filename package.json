{
  "name": "strava-mcp-unofficial",
  "version": "0.1.0",
  "description": "Unofficial local-first Strava MCP server for AI training and performance agents.",
  "type": "module",
  "bin": {
    "strava-mcp-unofficial": "dist/index.js",
    "strava-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "server.json",
    "docs/.nojekyll",
    "docs/.well-known",
    "docs/assets",
    "docs/*.md",
    "docs/*.txt",
    "docs/*.xml",
    "docs/index.html",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node scripts/smoke-tools.mjs",
    "test": "npm run typecheck && npm run build && npm run smoke && npm run smoke:http && npm run test:summary && npm run test:privacy-cache && npm run test:cli-ux",
    "test:summary": "node scripts/summary-fixture-test.mjs",
    "prepublishOnly": "npm test",
    "smoke:http": "node scripts/smoke-http.mjs",
    "test:privacy-cache": "node scripts/privacy-cache-test.mjs",
    "test:cli-ux": "node scripts/cli-ux-test.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "strava",
    "running",
    "cycling",
    "fitness",
    "training",
    "ai-agents"
  ],
  "author": "David Mosiah",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidmosiah/strava-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/davidmosiah/strava-mcp/issues"
  },
  "homepage": "https://stravamcp.vercel.app/",
  "mcpName": "io.github.davidmosiah/strava-mcp",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "dist/index.js"
}
